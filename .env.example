# =============================================================================
# MarketSense — Variables de Entorno
# =============================================================================
# Copia este archivo a .env y llena tus valores:
#   cp .env.example .env
#
# ¡NUNCA commitees .env al control de versiones!
# =============================================================================

# ── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Base de Datos (RDS PostgreSQL) ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/marketsense

# ── API de Noticias ──────────────────────────────────────────────────────────
# Obtén una clave en https://newsapi.org o usa otro proveedor de noticias financieras
NEWS_API_KEY=

# ── Aplicación ───────────────────────────────────────────────────────────────
FASTAPI_PORT=8000
NEXT_PUBLIC_API_URL=http://localhost:8000
