# ============================================================
# Python
# ============================================================
# Bytecode compilado — Python los genera automáticamente.
__pycache__/
*.pyc
*.pyo

# Empaquetado
*.egg-info/
dist/
build/

# ============================================================
# Entornos virtuales
# ============================================================
# Contiene TODAS las librerías instaladas (pandas, streamlit, etc.).
# Puede pesar más de 500MB. Cada persona lo recrea con: pip install -e ".[dev]"
.venv/
venv/
env/

# ============================================================
# Datos generados
# ============================================================
# El dataset de entrenamiento se regenera con: make dataset
# Puede pesar cientos de MB. No pertenece a Git.
data/

# ============================================================
# Modelos entrenados
# ============================================================
# Los artefactos de ML se regeneran con: make train
# Los archivos .pkl pesan decenas de MB. No pertenecen a Git.
models/

# ============================================================
# Claude Code (configuración local)
# ============================================================
.claude/

# ============================================================
# Variables de entorno
# ============================================================
# Contiene claves API, contraseñas, configuración sensible.
# NUNCA se debe commitear a Git. Solo .env.example se rastrea como plantilla.
.env

# ============================================================
# IDEs y editores
# ============================================================
.vscode/
.idea/
*.swp
*.swo

# ============================================================
# Sistema operativo
# ============================================================
# macOS crea .DS_Store en cada carpeta abierta en Finder.
# Windows crea Thumbs.db para miniaturas.
.DS_Store
Thumbs.db

# ============================================================
# Jupyter
# ============================================================
.ipynb_checkpoints/

# ============================================================
# Frontend (Next.js)
# ============================================================
frontend/node_modules/
frontend/.next/
frontend/out/

# ============================================================
# Caché de testing y linting
# ============================================================
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage

# ============================================================
# Archivos de entorno adicionales
# ============================================================
.env.local
.env.*.local